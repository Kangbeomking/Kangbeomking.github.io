  ttsEls.voice.value = saved || fallback || (ttsEls.voice.options[0] ? ttsEls.voice.options[0].value : '');
}
function ttsSpeakCurrent() {
  if (!ttsSupport) return;
  const block = ttsState.blocks[ttsState.index];
  if (!block) {
    ttsSetStatus('완료');
    ttsState.speaking = false;
    ttsState.paused = false;
    ttsClearHighlight();
    ttsUpdateMediaSession();
    return;
  }
  const token = ++ttsRunToken;
  ttsState.manualStop = false;
  speechSynthesis.cancel();
  const utterance = new SpeechSynthesisUtterance(block.text);
  const voice = ttsSelectedVoice();
  if (voice) {
    utterance.voice = voice;
    utterance.lang = voice.lang || 'ko-KR';
  } else {
    utterance.lang = 'ko-KR';
  }
  utterance.rate = ttsGetRate();
  utterance.pitch = 1;
  utterance.onstart = () => {
    if (token !== ttsRunToken) return;
    ttsState.speaking = true;
    ttsState.paused = false;
    ttsHighlight(ttsState.index);
    ttsSavePosition();
    ttsUpdateCurrent();
    ttsSetStatus('읽는 중');
    ttsUpdateMediaSession();
  };
  utterance.onend = () => {
    if (token !== ttsRunToken || ttsState.manualStop) return;
    ttsState.index += 1;
    if (ttsState.index < ttsState.blocks.length) {
      ttsSavePosition();
      ttsUpdateCurrent();
      setTimeout(ttsSpeakCurrent, 80);
    } else {
      localStorage.setItem(ttsStore.pos(ttsState.chapter), '0');
      ttsState.speaking = false;
      ttsState.paused = false;
      ttsClearHighlight();
      ttsSetStatus('완료');
      ttsUpdateCurrent();
      ttsStopMediaSession();
    }
  };
  utterance.onerror = () => {
    if (token !== ttsRunToken || ttsState.manualStop) return;
    ttsState.speaking = false;
    ttsState.paused = false;
    ttsSetStatus('오류');
    ttsUpdateMediaSession();
  };
  ttsState.utterance = utterance;
  speechSynthesis.speak(utterance);
}
function ttsStartCurrentChapter(useSaved) {
  if (!ttsSupport) return;
  const slug = ttsCurrentSlug();
  ttsLoadChapter(slug, useSaved);
  if (!ttsState.blocks.length) {
    ttsSetStatus('본문 없음');
    return;
  }
  const section = ttsCurrentSection();
  location.hash = section && section.node && section.node.id ? section.node.id : slug;
  ttsStartMediaSession();
  ttsSpeakCurrent();
}
function ttsPause() {
  if (!ttsSupport || !ttsState.speaking || ttsState.paused) return;
  speechSynthesis.pause();
  ttsPauseSessionAudio();
  ttsState.paused = true;
  ttsSetStatus('일시정지');
  ttsSavePosition();
  ttsUpdateCurrent();
  ttsUpdateMediaSession();
}
function ttsResume() {
  if (!ttsSupport) return;
  if (ttsState.paused) {
    ttsStartMediaSession();
    speechSynthesis.resume();
    ttsState.paused = false;
    ttsSetStatus('읽는 중');
    ttsUpdateCurrent();
    ttsUpdateMediaSession();
  } else {
    ttsStartCurrentChapter(true);
  }
}
function ttsStop() {
  if (!ttsSupport) return;
  ttsState.manualStop = true;
  ttsRunToken += 1;
  speechSynthesis.cancel();
  ttsStopMediaSession();
  ttsState.speaking = false;
  ttsState.paused = false;
  ttsSavePosition();
  ttsClearHighlight();
  ttsSetStatus('정지');
  ttsUpdateCurrent();
}
function ttsSkipSection(delta) {
  if (!ttsSupport) return;
  if (!ttsState.blocks.length) ttsLoadChapter(ttsCurrentSlug(), true);
  if (!ttsState.blocks.length || !ttsState.sections.length) return;
  let nextSection = ttsCurrentSectionIndex() + delta;
  if (nextSection < 0) {
    const chapterIdx = chapterIds.indexOf(ttsState.chapter);
    if (chapterIdx > 0) {
      const prevSlug = chapterIds[chapterIdx - 1];
      ttsLoadChapter(prevSlug, false);
      nextSection = Math.max(0, ttsState.sections.length - 1);
      ttsState.index = ttsSectionStart(nextSection);
      const section = ttsCurrentSection();
      location.hash = section && section.node && section.node.id ? section.node.id : prevSlug;
    } else {
      ttsState.index = ttsSectionStart(0);
    }
  } else if (nextSection >= ttsState.sections.length) {
    const chapterIdx = chapterIds.indexOf(ttsState.chapter);
    if (chapterIdx >= 0 && chapterIdx < chapterIds.length - 1) {
      const nextSlug = chapterIds[chapterIdx + 1];
      ttsLoadChapter(nextSlug, false);
      ttsState.index = ttsSectionStart(0);
      const section = ttsCurrentSection();
      location.hash = section && section.node && section.node.id ? section.node.id : nextSlug;
    } else {
      ttsState.index = ttsSectionStart(ttsState.sections.length - 1);
    }
  } else {
    ttsState.index = ttsSectionStart(nextSection);
    const section = ttsCurrentSection();
    location.hash = section && section.node && section.node.id ? section.node.id : ttsState.chapter;
  }
  ttsSavePosition();
  ttsStartMediaSession();
  ttsSpeakCurrent();
}
function ttsInit() {
  if (!ttsSupport) {
    ttsSetStatus('미지원');
    if (ttsEls.current) ttsEls.current.textContent = '이 브라우저는 즉석 낭독을 지원하지 않습니다.';
    if (ttsEls.dockTitle) ttsEls.dockTitle.textContent = '즉석 낭독 미지원';
    if (ttsEls.dockSubtitle) ttsEls.dockSubtitle.textContent = '이 브라우저는 즉석 낭독을 지원하지 않습니다.';
    ttsSetButtons(true);
    return;
  }
  const initialRate = localStorage.getItem(ttsStore.rate) || '1';
  if (ttsEls.rate) ttsEls.rate.value = initialRate;
  if (ttsEls.dockRate) ttsEls.dockRate.value = initialRate;
  ttsApplyRateLabel();
  if (ttsEls.rate) ttsEls.rate.addEventListener('input', ttsApplyRateLabel);
  if (ttsEls.dockRate) ttsEls.dockRate.addEventListener('input', ttsApplyRateLabel);
  ttsPopulateVoices();
  speechSynthesis.addEventListener('voiceschanged', ttsPopulateVoices);
  if (ttsEls.voice) {
    ttsEls.voice.addEventListener('change', () => localStorage.setItem(ttsStore.voice, ttsEls.voice.value));
  }
  ttsRegisterMediaSessionHandlers();
  ttsLoadChapter(ttsCurrentSlug(), true);
  const markAllSections = () => {
    try { chapterIds.forEach(slug => ttsCollectBlocks(slug)); } catch {}
  };
  if ('requestIdleCallback' in window) requestIdleCallback(markAllSections, { timeout: 1600 });
  else setTimeout(markAllSections, 300);
  [ttsEls.play, ttsEls.dockPlay].filter(Boolean).forEach(el => el.addEventListener('click', () => ttsStartCurrentChapter(false)));
  [ttsEls.pause, ttsEls.dockPause].filter(Boolean).forEach(el => el.addEventListener('click', ttsPause));
  [ttsEls.resume, ttsEls.dockResume].filter(Boolean).forEach(el => el.addEventListener('click', ttsResume));
  [ttsEls.stop, ttsEls.dockStop].filter(Boolean).forEach(el => el.addEventListener('click', ttsStop));
  [ttsEls.prev, ttsEls.dockPrev].filter(Boolean).forEach(el => el.addEventListener('click', () => ttsSkipSection(-1)));
  [ttsEls.next, ttsEls.dockNext].filter(Boolean).forEach(el => el.addEventListener('click', () => ttsSkipSection(1)));
  if (ttsEls.barToggle) ttsEls.barToggle.addEventListener('click', () => {
    if (ttsState.speaking && !ttsState.paused) ttsPause();
    else if (ttsState.paused) ttsResume();
    else ttsStartCurrentChapter(false);
  });
  if (ttsEls.barStop) ttsEls.barStop.addEventListener('click', ttsStop);
  if (ttsEls.barPrev) ttsEls.barPrev.addEventListener('click', () => ttsSkipSection(-1));
  if (ttsEls.barNext) ttsEls.barNext.addEventListener('click', () => ttsSkipSection(1));
  addEventListener('hashchange', () => {
    if (!ttsState.speaking && !ttsState.paused) {
      ttsLoadChapter(ttsCurrentSlug(), true);
    }
  });
  addEventListener('beforeunload', () => {
    if (ttsState.speaking || ttsState.paused) ttsSavePosition();
    speechSynthesis.cancel();
    ttsStopMediaSession();
  });
}
initMobileToc();
initAudiobookBarVisibility();
ttsInit();
</script>
