<!DOCTYPE html>

<html data-theme="light" lang="ko">
<head>
<meta charset="utf-8"/>
<meta content="width=device-width, initial-scale=1" name="viewport"/>
<title>현실의 괴물이 되는 길 — 웹북</title>
<meta content="실제 문제 · 흐름 · 제약요인 · 검증 · 실행 순서 · 병목" name="description"/>
<meta content="보이후드게임즈 강범" name="author"/>
<style>
:root {
  --bg: #f7f2ea;
  --paper: #fffaf2;
  --paper-2: #fbf5ec;
  --ink: #1f1a17;
  --muted: #766a5d;
  --line: rgba(49, 38, 26, .15);
  --accent: #9a4b24;
  --accent-2: #4d3a2f;
  --code-bg: #2a211c;
  --code-ink: #f9ead6;
  --shadow: 0 20px 60px rgba(41, 30, 21, .12);
  --reading-scale: 1;
  --sidebar-w: 328px;
  --radius: 22px;
}
html[data-theme="dark"] {
  --bg: #151210;
  --paper: #211b17;
  --paper-2: #2a221d;
  --ink: #f5eadd;
  --muted: #b9a898;
  --line: rgba(255, 238, 216, .16);
  --accent: #e2a064;
  --accent-2: #f1d2b5;
  --code-bg: #0d0b0a;
  --code-ink: #ffe7c4;
  --shadow: 0 20px 60px rgba(0, 0, 0, .35);
}
* { box-sizing: border-box; }
html { scroll-behavior: smooth; }
body {
  margin: 0;
  background:
    radial-gradient(circle at top left, rgba(154, 75, 36, .12), transparent 34rem),
    linear-gradient(135deg, var(--bg), var(--paper-2));
  color: var(--ink);
  font-family: -apple-system, BlinkMacSystemFont, "Apple SD Gothic Neo", "Noto Sans KR", "Malgun Gothic", "Segoe UI", sans-serif;
  line-height: 1.78;
  word-break: keep-all;
  overflow-wrap: break-word;
}
a { color: inherit; text-decoration-color: rgba(154, 75, 36, .4); text-underline-offset: .18em; }
a:hover { color: var(--accent); }
.progress { position: fixed; inset: 0 0 auto 0; height: 4px; z-index: 40; background: transparent; }
.progress span { display:block; width:0%; height:100%; background: linear-gradient(90deg, var(--accent), #d49b5b); }
.skip-link { position: absolute; top: -80px; left: 16px; background: var(--accent); color: white; padding: 8px 12px; z-index: 100; border-radius: 8px; }
.skip-link:focus { top: 12px; }
.layout { min-height: 100vh; display: grid; grid-template-columns: var(--sidebar-w) minmax(0, 1fr); }
.sidebar {
  position: sticky;
  top: 0;
  height: 100vh;
  padding: 24px 18px 18px;
  border-right: 1px solid var(--line);
  background: color-mix(in srgb, var(--paper) 86%, transparent);
  backdrop-filter: blur(16px);
  overflow: auto;
  z-index: 30;
}
.brand { display:block; text-decoration:none; margin-bottom: 18px; }
.brand small { display:block; color: var(--accent); letter-spacing: .16em; font-weight: 800; font-size: 11px; text-transform: uppercase; }
.brand strong { display:block; font-size: 23px; line-height: 1.25; margin-top: 8px; }
.brand span { display:block; color: var(--muted); font-size: 13px; margin-top: 8px; }
.controls { display:grid; grid-template-columns: repeat(3, 1fr); gap: 8px; margin: 16px 0; }
button, input {
  font: inherit;
}
button {
  border: 1px solid var(--line);
  background: var(--paper-2);
  color: var(--ink);
  border-radius: 999px;
  padding: 8px 10px;
  cursor: pointer;
}
button:hover { border-color: color-mix(in srgb, var(--accent) 48%, var(--line)); color: var(--accent); }
.search-box { position: relative; margin: 12px 0 8px; }
.search-box input {
  width: 100%; border: 1px solid var(--line); border-radius: 14px;
  background: var(--paper); color: var(--ink); padding: 11px 12px;
  outline: none;
}
.search-box input:focus { border-color: var(--accent); box-shadow: 0 0 0 3px rgba(154, 75, 36, .12); }
.search-meta { color: var(--muted); font-size: 12px; margin: 4px 2px 14px; }
.toc-cover, .toc summary a, .toc li a { text-decoration: none; }
.toc-cover { display:block; padding: 10px 12px; border-radius: 12px; font-weight: 800; color: var(--accent); }
.toc-chapter { margin: 7px 0; border-top: 1px solid var(--line); padding-top: 7px; }
.toc-chapter summary { cursor: pointer; list-style: none; padding: 8px 2px; font-weight: 800; line-height: 1.35; }
.toc-chapter summary::-webkit-details-marker { display:none; }
.toc-chapter summary a { display:inline; }
.toc-chapter ol { margin: 2px 0 8px; padding: 0 0 0 18px; color: var(--muted); font-size: 13px; line-height: 1.45; }
.toc-chapter li { margin: 6px 0; }
.toc a.active { color: var(--accent); font-weight: 900; }
.sidebar-footer { margin-top: 24px; padding-top: 16px; border-top: 1px solid var(--line); color: var(--muted); font-size: 12px; }
.main { min-width: 0; }
.reader { max-width: 980px; margin: 0 auto; padding: 36px 44px 96px; }
.cover {
  min-height: calc(100vh - 72px);
  display: grid;
  align-content: center;
  padding: 40px 0 56px;
}
.cover-panel {
  background: linear-gradient(145deg, color-mix(in srgb, var(--paper) 92%, transparent), color-mix(in srgb, var(--paper-2) 95%, transparent));
  border: 1px solid var(--line);
  border-radius: 34px;
  box-shadow: var(--shadow);
  padding: clamp(30px, 5vw, 64px);
  position: relative;
  overflow: hidden;
}
.cover-panel::after {
  content:""; position:absolute; width: 300px; height: 300px; right:-110px; top:-90px; border-radius: 50%;
  background: radial-gradient(circle, rgba(154,75,36,.22), transparent 62%);
}
.eyebrow { color: var(--accent); font-weight: 900; letter-spacing: .18em; text-transform: uppercase; font-size: 12px; }
.cover h1 { font-size: clamp(42px, 8vw, 86px); line-height: 1.04; letter-spacing: -.06em; margin: 16px 0 18px; }
.cover p.lead { color: var(--muted); font-size: clamp(17px, 2vw, 22px); max-width: 720px; margin: 0 0 28px; }
.book-author { display:inline-flex; align-items:center; gap: 8px; margin: 2px 0 18px; padding: 8px 13px; border: 1px solid var(--line); border-radius: 999px; background: color-mix(in srgb, var(--accent) 8%, transparent); color: var(--accent); font-size: 14px; font-weight: 900; }
.brand .brand-author { color: var(--accent); font-weight: 900; margin-top: 6px; }
.cover-actions { display:flex; flex-wrap: wrap; gap: 10px; margin: 20px 0 32px; }
.cover-actions a { text-decoration: none; border: 1px solid var(--line); padding: 11px 16px; border-radius: 999px; font-weight: 800; background: var(--paper-2); }
.cover-actions a.primary { background: var(--accent); border-color: var(--accent); color: #fff; }
.mobile-only { display: none !important; }
.chapter-cards { display:grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 12px; margin-top: 24px; }
.chapter-card { display:block; text-decoration: none; background: color-mix(in srgb, var(--paper-2) 84%, transparent); border: 1px solid var(--line); border-radius: 18px; padding: 16px; min-height: 154px; }
.chapter-card:hover { transform: translateY(-2px); box-shadow: 0 12px 30px rgba(0,0,0,.08); }
.chapter-label { display:inline-flex; align-items:center; justify-content:center; min-width: 42px; height: 28px; padding: 0 9px; border-radius: 999px; background: color-mix(in srgb, var(--accent) 14%, transparent); color: var(--accent); font-weight: 900; font-size: 12px; }
.chapter-card strong { display:block; font-size: 18px; line-height: 1.35; margin: 12px 0 8px; }
.chapter-card small { color: var(--muted); display:-webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow:hidden; }
.chapter {
  margin: 48px 0;
  padding: clamp(28px, 5vw, 68px);
  background: var(--paper);
  border: 1px solid var(--line);
  border-radius: var(--radius);
  box-shadow: var(--shadow);
  font-size: calc(18px * var(--reading-scale));
}
.source-note { color: var(--muted); font-size: 12px; margin-bottom: 16px; border-bottom: 1px solid var(--line); padding-bottom: 12px; }
.chapter h1, .chapter h2, .chapter h3, .chapter h4 { line-height: 1.24; letter-spacing: -.035em; scroll-margin-top: 22px; word-break: keep-all; }
.chapter h1 { font-size: clamp(34px, 6vw, 60px); margin: 0 0 32px; padding-bottom: 22px; border-bottom: 2px solid var(--line); }
.chapter h2 { font-size: clamp(25px, 3.6vw, 38px); margin: 3.2em 0 .75em; }
.chapter h3 { font-size: clamp(21px, 2.6vw, 28px); margin: 2.2em 0 .7em; }
.chapter h4 { font-size: 1.1em; margin: 1.6em 0 .6em; }
.tts-section-code {
  display: inline-flex;
  vertical-align: middle;
  margin: 0 .55em .12em 0;
  padding: .18em .48em;
  border-radius: 999px;
  background: color-mix(in srgb, var(--accent) 12%, transparent);
  color: var(--accent);
  border: 1px solid color-mix(in srgb, var(--accent) 24%, var(--line));
  font-size: .44em;
  font-weight: 900;
  letter-spacing: .02em;
}
.anchor { float: left; margin-left: -1.1em; width: 1em; opacity: 0; text-decoration: none; color: var(--accent); }
h1:hover .anchor, h2:hover .anchor, h3:hover .anchor, h4:hover .anchor { opacity: .8; }
.chapter p { margin: 1em 0; }
.chapter blockquote {
  margin: 1.4em 0;
  padding: 1.1em 1.2em;
  border-left: 5px solid var(--accent);
  background: color-mix(in srgb, var(--accent) 8%, transparent);
  border-radius: 0 16px 16px 0;
}
.chapter blockquote p:first-child { margin-top: 0; }
.chapter blockquote p:last-child { margin-bottom: 0; }
.chapter ul, .chapter ol { padding-left: 1.35em; }
.chapter li { margin: .32em 0; }
.chapter hr { border: none; border-top: 1px solid var(--line); margin: 2.2em 0; }
.chapter strong { font-weight: 900; }
.chapter code { font-family: "SFMono-Regular", Consolas, "Liberation Mono", Menlo, monospace; font-size: .9em; background: color-mix(in srgb, var(--accent) 10%, transparent); padding: .12em .35em; border-radius: 6px; }
.chapter pre {
  background: var(--code-bg); color: var(--code-ink); padding: 18px 20px; border-radius: 16px;
  overflow: auto; line-height: 1.6; box-shadow: inset 0 0 0 1px rgba(255,255,255,.06);
}
.chapter pre code { background: transparent; color: inherit; padding: 0; white-space: pre; }
.table-wrap { overflow-x: auto; margin: 1.5em 0; border: 1px solid var(--line); border-radius: 16px; }
table { border-collapse: collapse; width: 100%; min-width: 520px; background: var(--paper); }
th, td { border-bottom: 1px solid var(--line); padding: 10px 12px; vertical-align: top; }
th { background: color-mix(in srgb, var(--accent) 9%, transparent); text-align: left; font-weight: 900; }
tr:last-child td { border-bottom: none; }
.chapter-footnotes { margin-top: 3em; padding-top: 1em; border-top: 1px solid var(--line); color: var(--muted); font-size: .9em; }
.chapter-nav { display:grid; grid-template-columns: 1fr auto 1fr; gap: 12px; margin-top: 56px; padding-top: 22px; border-top: 1px solid var(--line); align-items: stretch; }
.chapter-nav a { text-decoration: none; border: 1px solid var(--line); border-radius: 16px; padding: 12px 14px; background: var(--paper-2); font-weight: 900; }
.chapter-nav span { color: var(--muted); font-weight: 500; font-size: .9em; }
.chapter-nav .next { text-align: right; }
.chapter-nav .toc-jump { align-self: center; white-space: nowrap; }
.empty-state { display: none; padding: 36px; border-radius: 22px; border: 1px dashed var(--line); color: var(--muted); background: var(--paper); margin: 24px 0; }
body.searching .cover { min-height: auto; padding-bottom: 20px; }
body.searching .cover-panel { display: none; }
body.searching .chapter.hidden { display: none; }
body.searching .empty-state.show { display: block; }
.mobile-topbar { display:none; position: sticky; top:0; z-index:35; background: color-mix(in srgb, var(--paper) 92%, transparent); backdrop-filter: blur(14px); border-bottom: 1px solid var(--line); padding: 9px 14px; }
.mobile-topbar a { font-weight: 900; text-decoration:none; }
.mobile-reader-toc { display: none; }
.mobile-reader-toc-panel {
  margin-bottom: 18px;
  padding: 20px 18px;
  border: 1px solid var(--line);
  border-radius: 22px;
  background: linear-gradient(145deg, color-mix(in srgb, var(--paper) 94%, transparent), color-mix(in srgb, var(--paper-2) 96%, transparent));
  box-shadow: var(--shadow);
}
.mobile-reader-toc-kicker {
  display: inline-flex;
  color: var(--accent);
  font-size: 11px;
  font-weight: 900;
  letter-spacing: .16em;
  text-transform: uppercase;
}
.mobile-reader-toc h2 {
  margin: 10px 0 6px;
  font-size: clamp(26px, 6vw, 34px);
  line-height: 1.1;
  letter-spacing: -.04em;
}
.mobile-reader-toc p {
  margin: 0;
  color: var(--muted);
  font-size: 14px;
}
.mobile-reader-actions,
.mobile-reader-shortcuts {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 8px;
  margin-top: 14px;
}
.mobile-reader-shortcuts { grid-template-columns: 1fr 1fr; }
.mobile-reader-actions button,
.mobile-reader-shortcuts a {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 42px;
  border: 1px solid var(--line);
  border-radius: 999px;
  background: var(--paper-2);
  color: var(--ink);
  font-size: 13px;
  font-weight: 800;
  text-decoration: none;
}
.mobile-reader-shortcuts a.primary {
  background: var(--accent);
  border-color: var(--accent);
  color: #fff;
}
.mobile-reader-toc-nav { margin-top: 14px; }
.mobile-reader-toc-nav .toc-cover {
  margin-bottom: 8px;
  border: 1px solid var(--line);
  background: color-mix(in srgb, var(--accent) 8%, transparent);
}
.mobile-reader-toc-nav .toc-chapter { margin: 0; }
.mobile-reader-toc-nav .toc-chapter summary {
  padding: 12px 2px;
  font-size: 14px;
}
.mobile-reader-toc-nav .toc-chapter ol {
  padding-bottom: 10px;
  font-size: 12px;
}
@media (max-width: 980px) {
  .layout { grid-template-columns: 1fr; }
  .sidebar { display: none; }
  .mobile-topbar { display: flex; justify-content: space-between; align-items:center; }
  .mobile-reader-toc { display: block; }
  .desktop-only { display: none !important; }
  .mobile-only { display: inline-flex !important; }
  .reader { padding: 24px 16px 64px; }
  .chapter { padding: 26px 20px; border-radius: 18px; font-size: calc(16.5px * var(--reading-scale)); }
  .anchor { display: none; }
}
@media (max-width: 640px) {
  body { word-break: normal; }
  .controls { grid-template-columns: 1fr 1fr; }
  .cover h1 { font-size: 42px; }
  .chapter h1 { font-size: 32px; }
  .chapter-nav { grid-template-columns: 1fr; }
  .chapter-nav .next { text-align:left; }
  .mobile-reader-actions { grid-template-columns: 1fr 1fr; }
  .mobile-reader-shortcuts { grid-template-columns: 1fr; }
}
@media print {
  body { background: white; color: black; }
  .sidebar, .progress, .mobile-topbar, .chapter-nav, .source-note, .cover-actions { display:none !important; }
  .layout { display:block; }
  .reader { max-width: none; padding: 0; }
  .cover, .chapter { box-shadow:none; border:none; padding: 0; margin: 0 0 28px; page-break-before: always; background:white; }
  .chapter:first-of-type { page-break-before: auto; }
  a { text-decoration:none; color:black; }
}

/* Audiobook / instant TTS */
.audiobook-panel {
  margin: 14px 0 14px;
  padding: 14px;
  border: 1px solid var(--line);
  border-radius: 18px;
  background: color-mix(in srgb, var(--paper-2) 86%, transparent);
}
.audiobook-head {
  display: flex;
  justify-content: space-between;
  gap: 10px;
  align-items: center;
  margin-bottom: 8px;
}
.audiobook-head strong { font-weight: 900; }
.tts-status {
  display: inline-flex;
  align-items: center;
  min-height: 24px;
  padding: 2px 9px;
  border-radius: 999px;
  background: color-mix(in srgb, var(--accent) 12%, transparent);
  color: var(--accent);
  font-size: 11px;
  font-weight: 900;
  white-space: nowrap;
}
.tts-current {
  color: var(--muted);
  font-size: 12px;
  line-height: 1.45;
  min-height: 3em;
  margin: 8px 0 10px;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}
.tts-controls {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 8px;
}
.tts-controls .wide { grid-column: 1 / -1; }
.tts-row { margin-top: 11px; }
.tts-row label {
  display: flex;
  justify-content: space-between;
  gap: 8px;
  align-items: center;
  color: var(--muted);
  font-size: 12px;
  font-weight: 800;
  margin-bottom: 5px;
}
.tts-row input[type="range"], .tts-row select { width: 100%; }
.tts-row select {
  border: 1px solid var(--line);
  border-radius: 12px;
  background: var(--paper);
  color: var(--ink);
  padding: 8px 10px;
  outline: none;
}
.tts-row select:focus { border-color: var(--accent); box-shadow: 0 0 0 3px rgba(154, 75, 36, .12); }
.tts-note {
  margin: 9px 0 0;
  color: var(--muted);
  font-size: 11px;
  line-height: 1.45;
}
.chapter .tts-speaking {
  background: color-mix(in srgb, var(--accent) 11%, transparent);
  border-radius: 10px;
  box-shadow: -8px 0 0 color-mix(in srgb, var(--accent) 46%, transparent);
  transition: background .18s ease, box-shadow .18s ease;
}


/* Fixed bottom audiobook player */
body { padding-bottom: calc(92px + env(safe-area-inset-bottom, 0px)); }
.audiobook-dock {
  position: fixed;
  left: var(--sidebar-w);
  right: 0;
  bottom: 0;
  z-index: 85;
  padding: 10px clamp(14px, 3vw, 28px) calc(10px + env(safe-area-inset-bottom, 0px));
  border-top: 1px solid var(--line);
  background: color-mix(in srgb, var(--paper) 88%, transparent);
  backdrop-filter: blur(18px);
  -webkit-backdrop-filter: blur(18px);
  box-shadow: 0 -18px 42px rgba(31, 26, 23, .13);
}
.audiobook-dock__inner {
  max-width: 1120px;
  margin: 0 auto;
  display: grid;
  grid-template-columns: minmax(0, 1fr) auto minmax(150px, 210px);
  align-items: center;
  gap: 14px;
}
.audiobook-dock__meta {
  min-width: 0;
  display: grid;
  grid-template-columns: auto minmax(0, 1fr);
  gap: 10px 12px;
  align-items: center;
}
.audiobook-dock__badge {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 38px;
  height: 38px;
  border-radius: 999px;
  background: color-mix(in srgb, var(--accent) 14%, transparent);
  color: var(--accent);
  font-weight: 950;
  border: 1px solid color-mix(in srgb, var(--accent) 24%, var(--line));
}
.audiobook-dock__title {
  font-weight: 950;
  line-height: 1.25;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}
.audiobook-dock__subtitle {
  color: var(--muted);
  font-size: 12px;
  line-height: 1.25;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  margin-top: 2px;
}
.audiobook-dock__status {
  justify-self: start;
  grid-column: 2;
  display: inline-flex;
  align-items: center;
  width: max-content;
  min-height: 22px;
  padding: 1px 8px;
  border-radius: 999px;
  background: color-mix(in srgb, var(--accent) 12%, transparent);
  color: var(--accent);
  font-size: 11px;
  font-weight: 900;
}
.audiobook-dock__controls {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 7px;
  white-space: nowrap;
}
.audiobook-dock__controls button {
  width: 42px;
  height: 42px;
  padding: 0;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  font-weight: 950;
}
.audiobook-dock__controls .dock-play {
  width: 52px;
  background: var(--accent);
  border-color: var(--accent);
  color: #fff;
  box-shadow: 0 8px 22px color-mix(in srgb, var(--accent) 24%, transparent);
}
.audiobook-dock__rate {
  display: grid;
  grid-template-columns: auto 1fr auto;
  align-items: center;
  gap: 8px;
  color: var(--muted);
  font-size: 12px;
  font-weight: 900;
}
.audiobook-dock__rate input[type="range"] { width: 100%; min-width: 84px; }
.audiobook-dock button:disabled,
.audiobook-panel button:disabled { opacity: .5; cursor: not-allowed; }
@media (max-width: 980px) {
  body { padding-bottom: calc(104px + env(safe-area-inset-bottom, 0px)); }
  .audiobook-dock { left: 0; padding-inline: 12px; }
  .audiobook-dock__inner { grid-template-columns: 1fr auto; gap: 9px; }
  .audiobook-dock__rate { grid-column: 1 / -1; }
}
@media (max-width: 640px) {
  .audiobook-dock__inner { grid-template-columns: 1fr; }
  .audiobook-dock__meta { grid-template-columns: auto minmax(0, 1fr); }
  .audiobook-dock__controls { justify-content: space-between; }
  .audiobook-dock__controls button { width: 40px; height: 40px; }
  .audiobook-dock__controls .dock-play { width: 48px; }
  .audiobook-dock__subtitle { max-width: 100%; }
}
@media print {
  body { padding-bottom: 0; }
  .audiobook-dock { display: none !important; }
}

@media print {
  .audiobook-panel { display: none !important; }
}


/* Always-visible bottom audiobook player */
body { padding-bottom: 104px; }
.reader { padding-bottom: 178px; }
.audiobook-bar {
  position: fixed;
  left: 50%;
  bottom: max(14px, env(safe-area-inset-bottom));
  transform: translateX(-50%);
